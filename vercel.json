{
  "regions": ["iad1", "sfo1"],
  "rewrites": [
    { "source": "/api/discover", "destination": "/api/discover" },
    { "source": "/api/wishlists/public/:id", "destination": "/api/public-wishlist?id=:id" },
    { "source": "/api/auth/:path*", "destination": "/api/auth" },
    { "source": "/api/wishlists/:path*", "destination": "/api/wishlists" },
    { "source": "/api/notifications/:path*", "destination": "/api/notifications" },
    { "source": "/sitemap.xml", "destination": "/api/sitemap" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Cache-Control", "value": "s-maxage=60, stale-while-revalidate=300" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
