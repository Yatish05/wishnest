{
  "rewrites": [
    { "source": "/api/auth/:path*", "destination": "/api/auth" },
    { "source": "/api/wishlists/:path*", "destination": "/api/wishlists" },
    { "source": "/api/notifications/:path*", "destination": "/api/notifications" },
    { "source": "/api/discover", "destination": "/api/search?type=discover" },
    { "source": "/sitemap.xml", "destination": "/api/sitemap" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
